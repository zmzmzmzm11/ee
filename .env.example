# EveBox Docker 环境变量配置
# 复制此文件为 .env 后修改:  cp .env.example .env

# ===== 镜像设置 =====
# EveBox Docker 镜像名:标签
EVEBOX_IMAGE=evebox:latest

# Git 版本标签 (构建时传入)
GIT_REV=unknown
BUILD_REV=unknown

# ===== 服务端口 =====
# EveBox Web 界面端口
EVEBOX_PORT=5636

# ===== 时区 =====
TZ=Asia/Shanghai

# ===== Elasticsearch 模式 =====
# ES 索引前缀
EVEBOX_INDEX=evebox

# ===== SQLite 模式 =====
# EVE JSON 输入目录 (挂载到容器的 /data)
EVE_INPUT_DIR=./data
# EVE JSON 文件路径 (容器内路径)
EVE_INPUT_FILE=/data/suricata-eve.json

# ===== 开发模式 =====
# Suricata 模拟器事件生成间隔 (秒)
EVE_INTERVAL=1.5
